---
import PowerVideo from '@/assets/power/2600 tool battery or AC LR.mp4';
import AcPowerSupply from '@/assets/power/ac_ps_01.png';
import AcPowerModes from '@/assets/power/ac_ps_04.webp';
import CarryHandleKit from '@/assets/power/ac_ps_02.png';

const powerCards = [
  {
    eyebrow: 'Multiple Power Options',
    body: 'VOLTORK™ tools can be powered either by Makita® 18V batteries or our AC power supply',
    image: AcPowerModes,
    alt: 'VOLTORK tools with battery and AC power options',
  },
  {
    eyebrow: 'AC Power Supply',
    body: 'Versatile AC power supply runs on any voltage between 100 and 240 VAC',
    image: AcPowerSupply,
    alt: 'NexTORK AC power supply',
  },
  {
    eyebrow: 'Carry Handle Accessory',
    body: 'Available carry handle makes storing the 24ft (7.3m) cable painless',
    image: CarryHandleKit,
    alt: 'Carry handle and cable storage accessory',
  },
];
---

<section id="powering-our-tools" class="bg-slate-50 py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
    <div class="max-w-3xl">
      <h2
        class="text-4xl font-semibold tracking-[-0.04em] text-slate-950 sm:text-5xl"
      >
        Powering Our Tools
      </h2>
    </div>

    <div
      class="mt-14 grid gap-8 lg:grid-cols-[minmax(0,0.84fr)_minmax(0,1.16fr)] lg:items-stretch lg:gap-10"
    >
      <div
        class="flex flex-col justify-between gap-6"
        data-power-carousel
      >
        <div class="relative min-h-[30rem] sm:min-h-[34rem]">
          {
            powerCards.map((card, index) => (
              <article
                data-slide
                data-active={index === 0 ? 'true' : 'false'}
                aria-hidden={index === 0 ? 'false' : 'true'}
                class:list={[
                  'absolute inset-0 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_20px_60px_rgba(15,23,42,0.05)] transition-all duration-500 ease-out',
                  index === 0
                    ? 'translate-y-0 opacity-100'
                    : 'pointer-events-none translate-y-4 opacity-0',
                ]}
              >
                <div class="flex h-full flex-col">
                  <div class="flex flex-1 items-center justify-center bg-white p-6 sm:p-8">
                    <img
                      src={card.image.src}
                      alt={card.alt}
                      class="h-full max-h-[15rem] w-full object-contain sm:max-h-[18rem]"
                    />
                  </div>
                  <div class="space-y-3 border-t border-slate-100 px-6 py-6 sm:px-8">
                    <p
                      class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-700"
                    >
                      {card.eyebrow}
                    </p>
                    <p class="max-w-[28ch] text-lg leading-8 text-slate-600">
                      {card.body}
                    </p>
                  </div>
                </div>
              </article>
            ))
          }
        </div>

        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            {
              powerCards.map((card, index) => (
                <button
                  type="button"
                  data-dot={index}
                  class:list={[
                    'h-2.5 rounded-full bg-slate-300 transition-all duration-300',
                    index === 0 ? 'w-10 bg-slate-950' : 'w-2.5 hover:bg-slate-500',
                  ]}
                  aria-label={`Show ${card.eyebrow}`}
                  aria-pressed={index === 0 ? 'true' : 'false'}
                />
              ))
            }
          </div>

          <div class="flex items-center gap-3">
            <button
              type="button"
              data-prev
              class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 transition-colors hover:border-slate-950 hover:text-slate-950"
              aria-label="Previous slide"
            >
              <svg
                viewBox="0 0 24 24"
                class="h-5 w-5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
              >
                <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </button>
            <button
              type="button"
              data-next
              class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 transition-colors hover:border-slate-950 hover:text-slate-950"
              aria-label="Next slide"
            >
              <svg
                viewBox="0 0 24 24"
                class="h-5 w-5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
              >
                <path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <article
        class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_20px_60px_rgba(15,23,42,0.06)]"
      >
        <div class="flex h-full items-center justify-center p-4 sm:p-6 lg:p-8">
          <video
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
            class="block aspect-[16/10] w-full bg-white object-contain"
          >
            <source src={PowerVideo} type="video/mp4" />
          </video>
        </div>
      </article>
    </div>
  </div>
</section>

<script>
  const carousels = document.querySelectorAll('[data-power-carousel]');
  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)'
  ).matches;

  carousels.forEach((carousel) => {
    const slides = Array.from(
      carousel.querySelectorAll<HTMLElement>('[data-slide]')
    );
    const dots = Array.from(
      carousel.querySelectorAll<HTMLButtonElement>('[data-dot]')
    );
    const previousButton = carousel.querySelector<HTMLButtonElement>('[data-prev]');
    const nextButton = carousel.querySelector<HTMLButtonElement>('[data-next]');

    if (!slides.length || !previousButton || !nextButton) {
      return;
    }

    let activeIndex = slides.findIndex(
      (slide) => slide.dataset.active === 'true'
    );
    let autoplay: ReturnType<typeof setInterval> | undefined;

    if (activeIndex < 0) {
      activeIndex = 0;
    }

    const render = (nextIndex: number) => {
      activeIndex = (nextIndex + slides.length) % slides.length;

      slides.forEach((slide, index) => {
        const isActive = index === activeIndex;
        slide.dataset.active = String(isActive);
        slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
        slide.classList.toggle('opacity-100', isActive);
        slide.classList.toggle('translate-y-0', isActive);
        slide.classList.toggle('pointer-events-none', !isActive);
        slide.classList.toggle('opacity-0', !isActive);
        slide.classList.toggle('translate-y-4', !isActive);
      });

      dots.forEach((dot, index) => {
        const isActive = index === activeIndex;
        dot.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        dot.classList.toggle('w-10', isActive);
        dot.classList.toggle('bg-slate-950', isActive);
        dot.classList.toggle('w-2.5', !isActive);
        dot.classList.toggle('bg-slate-300', !isActive);
      });
    };

    const stopAutoplay = () => {
      if (autoplay) {
        clearInterval(autoplay);
        autoplay = undefined;
      }
    };

    const startAutoplay = () => {
      stopAutoplay();

      if (prefersReducedMotion) {
        return;
      }

      autoplay = setInterval(() => {
        render(activeIndex + 1);
      }, 4800);
    };

    previousButton.addEventListener('click', () => {
      render(activeIndex - 1);
      startAutoplay();
    });

    nextButton.addEventListener('click', () => {
      render(activeIndex + 1);
      startAutoplay();
    });

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        render(index);
        startAutoplay();
      });
    });

    carousel.addEventListener('mouseenter', stopAutoplay);
    carousel.addEventListener('mouseleave', startAutoplay);
    carousel.addEventListener('focusin', stopAutoplay);
    carousel.addEventListener('focusout', startAutoplay);

    render(activeIndex);
    startAutoplay();
  });
</script>
