---
import IndustryBackdrop from '@/assets/tool.jpg';
import OilAndGasImage from '@/assets/industries/oil&gas.jpeg';

const industries = [
  {
    title: 'Mining',
    image:
      'https://images.unsplash.com/photo-1517089152318-42ec560349c0?auto=format&fit=crop&w=900&q=80',
    alt: 'Large open pit mine with haul roads',
    description:
      'Torque solutions for haul trucks, shovels, crushers, and high-load field maintenance in demanding mine environments.',
  },
  {
    title: 'Wind & Solar',
    image:
      'https://images.unsplash.com/photo-1466611653911-95081537e5b7?auto=format&fit=crop&w=900&q=80',
    alt: 'Wind turbine and solar field',
    description:
      'Consistent bolting performance for turbine service, tower assembly, solar structures, and renewable energy infrastructure.',
  },
  {
    title: 'Manufacturing',
    image:
      'https://images.unsplash.com/photo-1565008447742-97f6f38c985c?auto=format&fit=crop&w=900&q=80',
    alt: 'Industrial manufacturing equipment',
    description:
      'Reliable fastening for production lines, heavy equipment assembly, and plant maintenance where uptime matters.',
  },
  {
    title: 'Aerospace',
    image:
      'https://images.unsplash.com/photo-1436491865332-7a61a109cc05?auto=format&fit=crop&w=900&q=80',
    alt: 'Aircraft maintenance and aerospace assembly',
    description:
      'Precision-driven torque control for aerospace manufacturing, tooling, and critical maintenance workflows.',
  },
  {
    title: 'Railway',
    image:
      'https://images.unsplash.com/photo-1474487548417-781cb71495f3?auto=format&fit=crop&w=900&q=80',
    alt: 'Railway infrastructure and train maintenance',
    description:
      'Built for rail maintenance, rolling stock service, and infrastructure fastening across demanding field conditions.',
  },
  {
    title: 'Oil & Gas',
    image: OilAndGasImage.src,
    alt: 'Oil refinery skyline with smokestacks at dusk',
    description:
      'Robust torque performance for flanges, structural bolting, shutdown work, and critical energy sector applications.',
  },
];
---

<section id="industries" class="relative isolate overflow-hidden py-20 sm:py-24">
  <div class="absolute inset-0">
    <img
      src={IndustryBackdrop.src}
      alt=""
      aria-hidden="true"
      class="h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-slate-950/78"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(14,165,233,0.18),_transparent_38%)]"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-5xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.34em] text-sky-300">
        Industries We Serve
      </p>
      <h2
        class="mt-5 text-4xl font-semibold uppercase tracking-[-0.04em] text-white sm:text-5xl lg:text-6xl"
      >
        Powering Critical Industry With Precision Torque
      </h2>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-slate-200">
        NexTORK delivers industrial bolting systems engineered for the
        environments where uptime, repeatability, and operator safety are
        non-negotiable.
      </p>
    </div>

    <div class="mt-16 grid gap-x-10 gap-y-12 md:grid-cols-2 xl:grid-cols-3">
      {
        industries.map((industry) => (
          <article class="mx-auto flex max-w-sm flex-col items-center text-center">
            <div
              class="relative h-48 w-48 overflow-hidden border-[5px] border-white bg-slate-800 shadow-[0_24px_50px_rgba(2,6,23,0.45)] sm:h-56 sm:w-56"
              style="transform: skewX(-12deg);"
            >
              <img
                src={industry.image}
                alt={industry.alt}
                class="absolute inset-0 h-full w-full object-cover"
                style="transform: skewX(12deg) scale(1.12); transform-origin: center;"
                loading="lazy"
              />
            </div>

            <h3
              class="mt-7 text-3xl font-semibold uppercase tracking-[0.04em] text-white sm:text-[2rem]"
            >
              {industry.title}
            </h3>
            <p class="mt-4 text-lg leading-8 text-slate-200">
              {industry.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
