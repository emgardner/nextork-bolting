---
import ToolSpinVideo from '@/assets/1300 Tool Spin LR.mp4';
import HeroBackground from '@/assets/hero_background.png';
import VoltorkBrochure from '@/assets/brochure/Voltork_Brochure.pdf';
---

<section
  id="hero"
  class="relative isolate overflow-hidden bg-white text-slate-950 lg:min-h-[720px]"
>
  <div aria-hidden="true" class="absolute inset-0 bg-white"></div>
  <div
    aria-hidden="true"
    class="absolute inset-y-0 left-1/2 w-full max-w-7xl -translate-x-1/2 opacity-90"
    style={`background-image: url(${HeroBackground.src}); background-position: center bottom; background-repeat: no-repeat; background-size: cover;`}
  >
  </div>
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-gradient-to-b from-white/95 via-white/75 to-white/35"
  >
  </div>


  <div
    class="relative z-10 mx-auto box-border max-w-7xl px-6 pb-16 pt-28 sm:px-8 sm:pb-20 sm:pt-32 lg:min-h-[720px] lg:px-12 lg:py-20"
  >
        <div class="grid gap-12 lg:h-full lg:grid-cols-[minmax(0,0.96fr)_minmax(0,1.04fr)] lg:items-center lg:gap-10">
      <div
        class="contents lg:flex lg:h-full lg:max-w-2xl lg:flex-col lg:justify-center lg:gap-8"
      >
      <div class="order-1 max-w-2xl lg:max-w-none">
        <div class="space-y-5">
          <h1
            class="max-w-[12ch] text-5xl font-semibold tracking-[-0.05em] text-slate-950 sm:text-6xl xl:text-7xl"
          >
            Next Generation Bolting Solutions
          </h1>

          <p class="max-w-xl text-xl font-medium text-sky-800 sm:text-2xl">
            Precision Electric Torque Tools
          </p>

          <p class="max-w-lg text-base leading-8 text-slate-600 sm:text-lg">
            Engineered for precision, durability, performance.
          </p>
        </div>
      </div>

      <div class="order-3 max-w-2xl space-y-5 lg:max-w-none lg:pt-0">
        <div class="flex flex-col gap-4 sm:flex-row">
          <a
            href={VoltorkBrochure}
            download="VOLTORK Brochure.pdf"
            class="inline-flex items-center justify-center rounded-full bg-slate-950 px-8 py-4 text-base font-semibold text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-sky-800"
          >
            Learn More
          </a>
          <a
            href="#contact"
            class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white/80 px-8 py-4 text-base font-semibold text-slate-900 backdrop-blur-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-sky-300 hover:bg-sky-50"
          >
            Get In Touch
          </a>
        </div>
        <!--
        <div class="flex flex-wrap gap-3 text-sm text-slate-700">
          <div
            class="rounded-full border border-slate-200 bg-white/70 px-4 py-2 backdrop-blur-sm"
          >
            Precision Controls
          </div>
          <div
            class="rounded-full border border-slate-200 bg-white/70 px-4 py-2 backdrop-blur-sm"
          >
            Built for Durability
          </div>
          <div
            class="rounded-full border border-slate-200 bg-white/70 px-4 py-2 backdrop-blur-sm"
          >
            Performance Focused
          </div>
      </div>
      -->
      </div>
      </div>

      <div class="order-2 relative flex min-h-[20rem] items-center justify-center sm:min-h-[24rem] lg:min-h-[34rem] lg:justify-end">
        <div class="relative h-full w-full overflow-hidden rounded-[2rem]">
          <video
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
            class="block h-full w-full bg-white object-contain"
          >
            <source src={ToolSpinVideo} type="video/mp4" />
          </video>
        </div>
      </div>
    </div>
  </div>
</section>
