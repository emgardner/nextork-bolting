const featureGroups = [
  {
    title: 'Torque And Control',
    icon: TorqueAngleIcon.src,
    points: [
      'Torque or torque & angle modes',
      'Remote control capable',
    ],
  },
  {
    title: 'Precision And Calibration',
    icon: PrecisionIcon.src,
    points: [
      'Field configurable / calibratable',
      'Better than 3% accuracy',
    ],
  },
  {
    title: 'Industrial Performance',
    icon: PowerIcon.src,
    points: [
      'Industrial durability - all metal construction',
      'Brushless motor with advanced heat management',
    ],
  },
  {
    title: 'Field Serviceability',
    icon: AccessoriesIcon.src,
    points: [
      'Field replaceable square drives and reaction arms',
      'Designed and built in the USA',
    ],
  },
];
---

<section id="tools" class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
    <div class="space-y-8">
      <div class="space-y-4">
        <h2
          class="max-w-3xl text-4xl font-semibold tracking-[-0.04em] text-slate-950 sm:text-5xl"
        >
          Our Tools
        </h2>
      </div>

      <article
        class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_20px_60px_rgba(15,23,42,0.06)]"
      >
        <div
          class="flex h-full items-center justify-center p-4 sm:p-6 lg:p-8"
        >
          <video
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
            class="block aspect-[16/10] w-full object-contain"
          >
            <source src={AllToolsVideo} type="video/mp4" />
          </video>
        </div>
      </article>

      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        {
          featureGroups.map((group) => (
            <article class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-5 shadow-[0_16px_40px_rgba(15,23,42,0.04)]">
              <div class="mb-5 flex h-20 w-20 items-center justify-center rounded-[1.5rem] bg-white shadow-sm">
                <img
                  src={group.icon}
                  alt=""
                  class="h-14 w-14 object-contain"
                  aria-hidden="true"
                />
              </div>
              <div class="space-y-3">
                {group.points.map((point) => (
                  <div class="flex items-start gap-3">
                    <div class="mt-2 h-2.5 w-2.5 rounded-full bg-sky-600" />
                    <p class="text-base leading-7 text-slate-600">
                      {point}
                    </p>
                  </div>
                ))}
              </div>
            </article>
          ))
        }
      </div>

      <!--
      <div class="mt-16">
        <ToolGrid client:load tools={tools} />
      </div>

      <div class="mt-10 w-full text-center italic text-slate-500">
        All tool weights include reaction arm, square drive and battery
      </div>
      -->
    </div>
  </div>
</section>
