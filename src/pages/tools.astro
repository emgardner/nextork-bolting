    eyebrow: 'Torque Modes',
    text: 'Torque or torque & angle modes',
    tint: 'from-sky-50 via-white to-white',
    eyebrowTint: 'text-sky-700',
    border: 'hover:border-sky-300/70 hover:bg-sky-50/60',
  },
  {
    eyebrow: 'Remote Control',
    text: 'Remote control capable',
    tint: 'from-cyan-50 via-white to-white',
    eyebrowTint: 'text-cyan-700',
    border: 'hover:border-cyan-300/70 hover:bg-cyan-50/60',
  },
  {
    eyebrow: 'Field Calibration',
    text: 'Field configurable / calibratable',
    tint: 'from-blue-50 via-white to-white',
    eyebrowTint: 'text-blue-700',
    border: 'hover:border-blue-300/70 hover:bg-blue-50/60',
  },
  {
    eyebrow: 'Accuracy',
    text: 'Better than 3% accuracy',
    tint: 'from-indigo-50 via-white to-white',
    eyebrowTint: 'text-indigo-700',
    border: 'hover:border-indigo-300/70 hover:bg-indigo-50/60',
  },
  {
    eyebrow: 'Metal Construction',
    text: 'Industrial durability - all metal construction',
    tint: 'from-slate-100 via-white to-white',
    eyebrowTint: 'text-slate-700',
    border: 'hover:border-slate-300/80 hover:bg-slate-50/70',
  },
  {
    eyebrow: 'Heat Management',
    text: 'Brushless motor with advanced heat management',
    tint: 'from-amber-50 via-white to-white',
    eyebrowTint: 'text-amber-700',
    border: 'hover:border-amber-300/70 hover:bg-amber-50/60',
  },
  {
    eyebrow: 'Field Service',
    text: 'Field replaceable square drives and reaction arms',
    tint: 'from-emerald-50 via-white to-white',
    eyebrowTint: 'text-emerald-700',
    border: 'hover:border-emerald-300/70 hover:bg-emerald-50/60',
  },
  {
    eyebrow: 'USA Built',
    text: 'Designed and built in the USA',
    tint: 'from-rose-50 via-white to-white',
    eyebrowTint: 'text-rose-700',
    border: 'hover:border-rose-300/70 hover:bg-rose-50/60',
  },
];

const tools = [
  {
    name: 'NT200B',
    image: NT200B.src,
    specs: [
      ['Output Drive', '3/4" SQ', '3/4" SQ'],
      ['Max Torque', '200 ft-lb', '271 N-m'],
      ['Min Torque', '20 ft-lb', '27 N-m'],
      ['Max Speed', '60.1 RPM', '60.1 RPM'],
      ['System Accuracy', '<3%', '<3%'],
      ['Tool Weight', '9.0 lb', '4.1 kg'],
      ['Total Weight', '10.6 lb', '4.8 kg'],
      ['Power Source', 'Battery/AC', 'Battery/AC'],
      ['Warranty', '1 year limited', '1 year limited'],
    ],
  },
  {
    name: 'NT500B',
    image: NT500B.src,
    specs: [
      ['Output Drive', '3/4" or 1" SQ', '3/4" or 1" SQ'],
      ['Max Torque', '500 ft-lb', '678 N-m'],
      ['Min Torque', '50 ft-lb', '68 N-m'],
      ['Max Speed', '17.4 RPM', '17.4 RPM'],
      ['System Accuracy', '<3%', '<3%'],
      ['Tool Weight', '10.0 lb', '4.5 kg'],
      ['Total Weight', '11.7 lb', '5.3 kg'],
      ['Power Source', 'Battery/AC', 'Battery/AC'],
      ['Warranty', '1 year limited', '1 year limited'],
    ],
  },
  {
    name: 'NT800B',
    image: NT800B.src,
    specs: [
      ['Output Drive', '3/4" or 1" SQ', '3/4" or 1" SQ'],
      ['Max Torque', '800 ft-lb', '1085 N-m'],
      ['Min Torque', '80 ft-lb', '108 N-m'],
      ['Max Speed', '12.2 RPM', '12.2 RPM'],
      ['System Accuracy', '<3%', '<3%'],
      ['Tool Weight', '10.0 lb', '4.5 kg'],
      ['Total Weight', '13.4 lb', '6.1 kg'],
      ['Power Source', 'Battery/AC', 'Battery/AC'],
      ['Warranty', '1 year limited', '1 year limited'],
    ],
  },
  {
    name: 'NT1300B',
    image: NT1300B.src,
    specs: [
      ['Output Drive', '1" SQ', '1" SQ'],
      ['Max Torque', '1300 ft-lb', '1763 N-m'],
      ['Min Torque', '130 ft-lb', '176 N-m'],
      ['Max Speed', '6.6 RPM', '6.6 RPM'],
      ['System Accuracy', '<3%', '<3%'],
      ['Tool Weight', '11.3 lb', '5.1 kg'],
      ['Total Weight', '14.9 lb', '6.8 kg'],
      ['Power Source', 'Battery/AC', 'Battery/AC'],
      ['Warranty', '1 year limited', '1 year limited'],
    ],
  },
  {
    name: 'NT2600B',
    image: NT2600B.src,
    specs: [
      ['Output Drive', '1" or 1-1/2" SQ', '1" or 1-1/2" SQ'],
      ['Max Torque', '2600 ft-lb', '3525 N-m'],
      ['Min Torque', '260 ft-lb', '353 N-m'],
      ['Max Speed', '3.0 RPM', '3.0 RPM'],
      ['System Accuracy', '<3%', '<3%'],
      ['Tool Weight', '19.9 lb', '9.0 kg'],
      ['Total Weight', '19.9 lb', '9.0 kg'],
      ['Power Source', 'Battery/AC', 'Battery/AC'],
      ['Warranty', '1 year limited', '1 year limited'],
    ],
  },
];
---

<Layout>
  <main class="bg-slate-100 text-slate-950">
    <section class="bg-slate-50 pt-28 sm:pt-32">
      <div class="mx-auto max-w-7xl px-6 pb-16 sm:px-8 sm:pb-20 lg:px-12">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.34em] text-sky-700">
            Tool Features
          </p>
          <h1 class="mt-4 text-4xl font-semibold tracking-[-0.04em] text-slate-950 sm:text-5xl">
            Core capabilities across the VOLTORK range
          </h1>
        </div>

        <article class="mt-10 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_24px_70px_rgba(15,23,42,0.08)]">
          <div class="p-4 sm:p-6 lg:p-8">
            <video
              id="tools-intro-video"
              data-videos={JSON.stringify(introVideos)}
              autoplay
              muted
              playsinline
              preload="metadata"
              class="block aspect-[16/9] w-full object-contain"
            >
              <source src={introVideos[0]} type="video/mp4" />
            </video>
          </div>
        </article>

        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {
            capabilities.map((item) => (
              <article
                class:list={[
                  'group relative overflow-hidden rounded-[1.6rem] border border-slate-200 bg-white shadow-[0_18px_45px_rgba(15,23,42,0.05)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_24px_60px_rgba(15,23,42,0.1)]',
                  item.border,
                ]}
              >
                <div
                  aria-hidden="true"
                  class:list={[
                    'absolute inset-0 bg-gradient-to-br opacity-95',
                    item.tint,
                  ]}
                >
                </div>

                <div class="relative flex h-full flex-col p-6 sm:p-7">
                  <p
                    class:list={[
                      'text-xs font-semibold uppercase tracking-[0.24em]',
                      item.eyebrowTint,
                    ]}
                  >
                    {item.eyebrow}
                  </p>
                  <p class="mt-4 text-lg font-medium leading-8 text-slate-800">
                    {item.text}
                  </p>

                  <div class="mt-6 h-1 w-16 rounded-full bg-slate-900/10"></div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-white pt-28 sm:pt-32">
      <div class="mx-auto max-w-7xl px-6 pb-16 sm:px-8 sm:pb-20 lg:px-12">
        <div class="grid gap-12 lg:grid-cols-[minmax(0,0.78fr)_minmax(0,1.22fr)] lg:items-center">
          <div class="max-w-2xl">
            <p class="text-sm font-semibold uppercase tracking-[0.34em] text-sky-700">
              VOLTORK Tools
            </p>
            <h1 class="mt-4 text-4xl font-semibold tracking-[-0.04em] text-slate-950 sm:text-5xl">
              Modular electric torque system
            </h1>
            <p class="mt-5 max-w-xl text-lg leading-8 text-slate-600">
              Shared tooling architecture with interchangeable components,
              accessories, and coverage from 200 to 2600 ft-lb.
            </p>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <a
                href={ProductBrochure}
                download="VOLTORK Product Brochure.pdf"
                class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-base font-semibold text-slate-950 transition-transform duration-300 hover:-translate-y-0.5"
              >
                Download Brochure
              </a>
              <a
                href="mailto:info@nextork.net?subject=VOLTORK%20Inquiry"
                class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-8 py-4 text-base font-semibold text-slate-950 transition-transform duration-300 hover:-translate-y-0.5 hover:border-sky-300 hover:bg-sky-50"
              >
                Talk to NexTORK
              </a>
            </div>
          </div>

          <button
            type="button"
            data-chart-open
            class="group relative block w-full overflow-hidden rounded-[1.5rem] border border-slate-200 bg-slate-50 p-3 text-left shadow-[0_18px_50px_rgba(15,23,42,0.06)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_24px_60px_rgba(15,23,42,0.1)]"
            aria-label="Open modular torque system image full screen"
          >
            <img
              src={ToolChart.src}
              alt="VOLTORK modular torque system chart"
              class="block w-full object-contain"
            />
            <div class="pointer-events-none absolute inset-x-4 bottom-4 flex justify-end">
              <span class="rounded-full border border-white/80 bg-white/90 px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-slate-700 shadow-sm transition-transform duration-300 group-hover:-translate-y-0.5">
                View Full Screen
              </span>
            </div>
          </button>
        </div>

        <dialog
          id="tool-chart-modal"
          class="m-auto w-[min(96vw,92rem)] max-w-none overflow-hidden rounded-[2rem] border border-white/15 bg-white p-3 text-slate-950 shadow-[0_30px_90px_rgba(15,23,42,0.35)] backdrop:bg-slate-950/80 backdrop:backdrop-blur-sm"
        >
          <div class="flex items-center justify-end pb-3">
            <button
              type="button"
              data-chart-close
              class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-600 transition-colors hover:border-slate-950 hover:text-slate-950"
              aria-label="Close modular torque system image"
            >
              <svg
                viewBox="0 0 24 24"
                class="h-5 w-5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              >
                <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>
          <img
            src={ToolChart.src}
            alt="VOLTORK modular torque system chart"
            class="block max-h-[85vh] w-full object-contain"
          />
        </dialog>

        <div class="mt-14">
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.34em] text-sky-700">
              System Components
            </p>
            <h2 class="mt-4 text-4xl font-semibold tracking-[-0.04em] text-slate-950 sm:text-5xl">
              Modular torque system parts and accessories.
            </h2>
          </div>

          <div class="mt-8 overflow-x-auto pb-4">
            <div class="grid min-w-[70rem] gap-6 lg:grid-cols-2">
              {
                componentTables.map((rows) => (
                  <div class="overflow-hidden rounded-[1.5rem] border border-slate-300 bg-white shadow-[0_18px_50px_rgba(15,23,42,0.06)]">
                    <table class="w-full border-collapse text-left text-sm">
                      <thead class="bg-sky-100 text-slate-950">
                        <tr>
                          <th class="border-b border-slate-300 px-3 py-2 font-semibold">
                            Item
                          </th>
                          <th class="border-b border-slate-300 px-3 py-2 font-semibold">
                            Part No
                          </th>
                          <th class="border-b border-slate-300 px-3 py-2 font-semibold">
                            Description
                          </th>
                        </tr>
                      </thead>
                      <tbody>
                        {
                          rows.map((row, index) => (
                            <tr class={index % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
                              <td class="border-b border-slate-200 px-3 py-2 whitespace-nowrap text-slate-950">
                                {row[0]}
                              </td>
                              <td class="border-b border-slate-200 px-3 py-2 whitespace-nowrap text-slate-950">
                                {row[1]}
                              </td>
                              <td class="border-b border-slate-200 px-3 py-2 whitespace-nowrap text-slate-700">
                                {row[2]}
                              </td>
                            </tr>
                          ))
                        }
                      </tbody>
                    </table>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-slate-50 py-20 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.34em] text-sky-700">
            Tool Lineup
          </p>
          <h2 class="mt-4 text-4xl font-semibold tracking-[-0.04em] text-slate-950 sm:text-5xl">
            All tools with specification comparison.
          </h2>
        </div>

        <div class="mt-8 flex items-center justify-end">
          <div
            id="unit-toggle"
            class="inline-flex rounded-full border border-slate-200 bg-white p-1 shadow-sm"
          >
            <button
              type="button"
              data-unit="imperial"
              class="unit-toggle-btn rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition-colors"
              aria-pressed="true"
            >
              Imperial
            </button>
            <button
              type="button"
              data-unit="metric"
              class="unit-toggle-btn rounded-full px-4 py-2 text-sm font-semibold text-slate-600 transition-colors"
              aria-pressed="false"
            >
              Metric
            </button>
          </div>
        </div>

        <div class="mt-6 overflow-x-auto pb-4">
          <div class="flex min-w-max gap-6">
          {
            tools.map((tool) => (
              <article class="flex w-[21rem] shrink-0 flex-col rounded-[1.75rem] border border-slate-200 bg-white p-5 shadow-[0_18px_50px_rgba(15,23,42,0.06)]">
                <div class="flex h-72 items-center justify-center rounded-[1.5rem] bg-slate-100 p-4">
                  <img
                    src={tool.image}
                    alt={tool.name}
                    class="h-56 w-auto max-w-full object-contain"
                    loading="lazy"
                  />
                </div>
                <h3 class="mt-5 text-2xl font-semibold text-slate-950">
                  {tool.name}
                </h3>
                <div class="mt-4 overflow-hidden rounded-[1rem] border border-slate-200">
                  <table class="w-full whitespace-nowrap text-left text-sm leading-6">
                    <tbody>
                      {
                        tool.specs.map(([label, imperial, metric], index) => (
                          <tr class={index % 2 === 0 ? 'bg-slate-50' : 'bg-white'}>
                            <th class="w-[42%] whitespace-nowrap border-b border-slate-200 px-3 py-2 font-semibold text-slate-950">
                              {label}
                            </th>
                            <td
                              class="border-b border-slate-200 px-3 py-2 whitespace-nowrap text-slate-600"
                              data-imperial={imperial}
                              data-metric={metric}
                            >
                              {imperial}
                            </td>
                          </tr>
                        ))
                      }
                    </tbody>
                  </table>
                </div>
              </article>
            ))
          }
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>

<script>
  const introVideo = document.getElementById('tools-intro-video');
  const toggle = document.getElementById('unit-toggle');
  const valueCells = document.querySelectorAll('[data-imperial]');
  const chartOpenButton = document.querySelector('[data-chart-open]');
  const chartModal = document.getElementById('tool-chart-modal');
  const chartCloseButton = document.querySelector('[data-chart-close]');

  if (introVideo) {
    const sources = JSON.parse(introVideo.getAttribute('data-videos') || '[]');
    let currentVideoIndex = 0;

    const playCurrentVideo = () => {
      if (sources.length === 0) return;
      introVideo.src = sources[currentVideoIndex];
      introVideo.play().catch(() => {});
    };

    introVideo.addEventListener('ended', () => {
      currentVideoIndex = (currentVideoIndex + 1) % sources.length;
      playCurrentVideo();
    });

    playCurrentVideo();
  }

  if (toggle && valueCells.length > 0) {
    const buttons = toggle.querySelectorAll('.unit-toggle-btn');

    const setUnit = (unit) => {
      valueCells.forEach((cell) => {
        const value = cell.getAttribute(
          unit === 'metric' ? 'data-metric' : 'data-imperial'
        );

        if (value) {
          cell.textContent = value;
        }
      });

      buttons.forEach((button) => {
        const active = button.getAttribute('data-unit') === unit;
        button.setAttribute('aria-pressed', active ? 'true' : 'false');
        button.classList.toggle('bg-slate-950', active);
        button.classList.toggle('text-white', active);
        button.classList.toggle('text-slate-600', !active);
      });
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const unit = button.getAttribute('data-unit');
        if (unit) setUnit(unit);
      });
    });

    setUnit('imperial');
  }

  if (chartOpenButton && chartModal) {
    chartOpenButton.addEventListener('click', () => {
      if (typeof chartModal.showModal === 'function') {
        chartModal.showModal();
      } else {
        chartModal.setAttribute('open', 'true');
      }
    });

    chartCloseButton?.addEventListener('click', () => {
      chartModal.close();
    });

    chartModal.addEventListener('click', (event) => {
      if (event.target === chartModal) {
        chartModal.close();
      }
    });
  }
</script>
