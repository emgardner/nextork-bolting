---
import Layout from '../layouts/Layout.astro';
import ToolChart from '@/assets/pages/tools/Tool Chart.png';
import IntroVideo from '@/assets/pages/tools/Intro LR.mp4';
import AllToolsVideo from '@/assets/pages/tools/All Tools text web LR.mp4';
import ChangeoverVideo from '@/assets/pages/tools/2600 tool changeover LR.mp4';
import NT200B from '@/assets/pages/tools/NT200B_SIDE.webp';
import NT500B from '@/assets/pages/tools/NT500B_SIDE.webp';
import NT800B from '@/assets/pages/tools/NT800B_SIDE.webp';
import NT1300B from '@/assets/pages/tools/NT1300B_SIDE.webp';
